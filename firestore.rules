rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Each user can only read/write their own document metadata and subcollections (like chunks)
    match /users/{userId}/documents/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Allow recursive access to child paths (e.g. chunks/0, chunks/1)
      match /{allPaths=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // User profile data (display name, preferences, etc.)
    match /users/{userId}/profile/{profileDoc} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Block all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
